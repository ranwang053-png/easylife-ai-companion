DATABASE_URL=postgresql://easylife_app:change-me@localhost:5432/easylife

# Generate independent high-entropy values. Never reuse one secret for another purpose.
PHONE_LOOKUP_PEPPER=replace-with-secret
PHONE_ENCRYPTION_KEY=replace-with-aead-key
SMS_CODE_PEPPER=replace-with-secret
DEVICE_LOOKUP_PEPPER=replace-with-secret
IP_LOOKUP_PEPPER=replace-with-secret

# Request and response bodies must remain disabled in application logs.
LOG_HTTP_BODIES=false
