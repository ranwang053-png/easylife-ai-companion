HOST=127.0.0.1
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=false

# Disabled by default. Enable only in automated tests or an isolated local environment.
ENABLE_TEST_TRIGGERS=false

# Fixed tokens are used only by the local contract-test fixture when DATABASE_URL is absent.
FIXED_ACCESS_TOKEN=example-access-token-with-at-least-twenty-characters
FIXED_ROTATED_ACCESS_TOKEN=rotated-access-token-with-at-least-twenty-characters

# Setting DATABASE_URL enables the real PostgreSQL authentication implementation.
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/easylife

# HTTPS gateway accepting { phone, code, purpose } with a Bearer token.
SMS_PROVIDER_URL=https://sms-gateway.example.com/v1/codes
SMS_PROVIDER_TOKEN=replace-me
SMS_PROVIDER_MAX_ATTEMPTS=3

# Each value must be an independently generated base64-encoded 32-byte secret.
# Generate one value at a time with: openssl rand -base64 32
PHONE_LOOKUP_PEPPER=
PHONE_ENCRYPTION_KEY=
SMS_CODE_PEPPER=
DEVICE_PEPPER=
IP_PEPPER=
REFRESH_TOKEN_PEPPER=
DELETION_TOKEN_PEPPER=
ACCESS_TOKEN_KEY=

ACCESS_TOKEN_KEY_ID=current
# JSON object of previous key ids to base64 secrets, used during key rotation.
ACCESS_TOKEN_PREVIOUS_KEYS={}
ACCESS_TOKEN_ISSUER=easylife-api
ACCESS_TOKEN_AUDIENCE=easylife-ios

# Configure an HTTPS cleanup service before enabling physical account deletion
# when external files, caches, analytics, or provider data exist.
ACCOUNT_DELETION_CLEANUP_URL=
ACCOUNT_DELETION_CLEANUP_TOKEN=
# Set true only when all user data is currently contained in PostgreSQL.
ACCOUNT_DELETION_ALLOW_DATABASE_ONLY=false
ACCOUNT_DELETION_LEASE_SECONDS=300
ACCOUNT_DELETION_POLL_SECONDS=5
ACCOUNT_DELETION_MAX_BACKOFF_SECONDS=3600
AUTH_MAINTENANCE_INTERVAL_SECONDS=3600

# Request and response bodies, authorization headers, phone numbers, and profile data are never logged.
LOG_HTTP_BODIES=false
