HOST=127.0.0.1
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=false
# Comma-separated browser origins allowed to call this API.
# Example for GitHub Pages demo:
# ALLOWED_ORIGINS=https://ranwang053-png.github.io
ALLOWED_ORIGINS=

# Disabled by default. Enable only in automated tests or an isolated local environment.
ENABLE_TEST_TRIGGERS=false

# Fixed tokens are used only by the local contract-test fixture when DATABASE_URL is absent.
FIXED_ACCESS_TOKEN=example-access-token-with-at-least-twenty-characters
FIXED_ROTATED_ACCESS_TOKEN=rotated-access-token-with-at-least-twenty-characters
# Optional public portfolio demo token accepted by protected AI routes.
# This must match the Flutter demo token when EASYLIFE_DEMO_MODE=true.
PORTFOLIO_DEMO_ACCESS_TOKEN=

# Setting DATABASE_URL enables the real PostgreSQL authentication implementation.
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/easylife

# HTTPS gateway accepting { phone, code, purpose } with a Bearer token.
SMS_PROVIDER_URL=https://sms-gateway.example.com/v1/codes
SMS_PROVIDER_TOKEN=replace-me
SMS_PROVIDER_MAX_ATTEMPTS=3

# AI provider configuration. Use "fixed" for local contract tests and demos.
# Flutter must only call the Easylife backend; never put AI keys in the app.
AI_PROVIDER=fixed

# Capability routing based on docs/AI_CAPABILITY_MATRIX.md.
# Keep these as provider/model identifiers only. Real API keys belong below.
AI_COMPANION_PROVIDER=openai
AI_COMPANION_MODEL=gpt-5.5
AI_EMOTION_PROVIDER=anthropic
AI_EMOTION_MODEL=claude-sonnet-4.6
AI_EMOTION_JOURNAL_PROVIDER=anthropic
AI_EMOTION_JOURNAL_MODEL=claude-sonnet-4.6
AI_MEMORY_PROVIDER=anthropic
AI_MEMORY_MODEL=claude-sonnet-4.6
AI_PET_PROFILE_PROVIDER=anthropic
AI_PET_PROFILE_MODEL=claude-sonnet-4.6
AI_DAILY_FORTUNE_PROVIDER=openai
AI_DAILY_FORTUNE_MODEL=gpt-5.5
AI_PET_AVATAR_PROVIDER=openai
AI_PET_AVATAR_MODEL=gpt-image-1
AI_DIET_TEXT_PROVIDER=doubao
AI_DIET_TEXT_MODEL=doubao-seed-1-6
AI_DIET_VISION_PROVIDER=doubao
AI_DIET_VISION_MODEL=doubao-seed-1-6
AI_DIET_SEARCH_PROVIDER=doubao
AI_DIET_SEARCH_MODEL=doubao-seed-1-6
AI_FOOD_SEGMENTATION_PROVIDER=birefnet
AI_FOOD_SEGMENTATION_MODEL=BiRefNet
AI_FOOD_IMAGE_ENHANCEMENT=light

# Provider credentials and endpoints. Leave empty unless the provider is enabled.
# One OpenAI project key can be reused by multiple OpenAI-routed capabilities
# such as AI_DAILY_FORTUNE_MODEL and AI_PET_AVATAR_MODEL, as long as the project
# has permission to use those models.
OPENAI_API_KEY=
# Optional unified text model for OpenAI-compatible gateways. When set, it
# overrides OpenAI-routed text capability models, but not image generation.
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI-compatible gateway roots such as https://aihubmix.com are normalized to /v1.
# Optional override when image generation uses a different OpenAI-compatible key
# or gateway than text models.
AI_PET_AVATAR_API_KEY=
AI_PET_AVATAR_BASE_URL=https://api.openai.com/v1
# Optional directory for default pet avatar style reference images.
# Supports PNG/JPG/WebP. Relative paths resolve from backend/server cwd.
# If empty, the backend uses ../../style-references/pet-avatar.
AI_PET_AVATAR_STYLE_REFERENCE_DIR=
# Optional local proxy for Node.js provider calls, for example Clash.
# HTTPS_PROXY=http://127.0.0.1:7890
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
BIREFNET_API_KEY=
BIREFNET_BASE_URL=

# Each value must be an independently generated base64-encoded 32-byte secret.
# Generate one value at a time with: openssl rand -base64 32
PHONE_LOOKUP_PEPPER=
PHONE_ENCRYPTION_KEY=
SMS_CODE_PEPPER=
DEVICE_PEPPER=
IP_PEPPER=
REFRESH_TOKEN_PEPPER=
DELETION_TOKEN_PEPPER=
ACCESS_TOKEN_KEY=

ACCESS_TOKEN_KEY_ID=current
# JSON object of previous key ids to base64 secrets, used during key rotation.
ACCESS_TOKEN_PREVIOUS_KEYS={}
ACCESS_TOKEN_ISSUER=easylife-api
ACCESS_TOKEN_AUDIENCE=easylife-ios

# Configure an HTTPS cleanup service before enabling physical account deletion
# when external files, caches, analytics, or provider data exist.
ACCOUNT_DELETION_CLEANUP_URL=
ACCOUNT_DELETION_CLEANUP_TOKEN=
# Set true only when all user data is currently contained in PostgreSQL.
ACCOUNT_DELETION_ALLOW_DATABASE_ONLY=false
ACCOUNT_DELETION_LEASE_SECONDS=300
ACCOUNT_DELETION_POLL_SECONDS=5
ACCOUNT_DELETION_MAX_BACKOFF_SECONDS=3600
AUTH_MAINTENANCE_INTERVAL_SECONDS=3600

# Request and response bodies, authorization headers, phone numbers, and profile data are never logged.
LOG_HTTP_BODIES=false
